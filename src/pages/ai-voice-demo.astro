---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const DEMO_NUMBER = '9032944808';
const DEMO_NUMBER_DISPLAY = '(903) 294-4808';

const steps = [
  {
    icon: 'lucide:phone-call',
    step: '01',
    title: 'AI answers instantly',
    body: 'Every call is answered in seconds — no rings into the void, no generic voicemail greeting. The AI introduces your business, engages the caller, and starts qualifying.',
  },
  {
    icon: 'lucide:shield-check',
    step: '02',
    title: 'Spam is filtered out',
    body: 'Robocalls, spam dialers, and obvious junk are identified and dismissed cleanly. They never make it to your inbox, your notification, or your attention. You never know they called.',
  },
  {
    icon: 'lucide:user-check',
    step: '03',
    title: 'Real people get handled — or flagged',
    body: 'Real callers get a useful experience. If they hang up before leaving a message, the system flags the call as a manual callback needed — so no genuine lead slips through the cracks.',
  },
];

const voicemailPoints = [
  'Caller intent captured before you listen',
  'Hang-ups from real callers flagged for callback',
  'No box to check, no audio scrubbing',
];

const spamPoints = [
  'Robocalls and dialers dismissed automatically',
  'Real callers get a professional, helpful experience',
  'You only see what matters',
];
---

<BaseLayout
  title="AI Answering Service Demo — Tenor Creative"
  description="Call (903) 294-4808 and experience a live AI answering service — real-time spam filtering, intelligent call screening, and automatic callback flagging. Built by Tenor Creative."
  path="/ai-voice-demo"
>
  {/* Hero */}
  <section class="relative pt-24 pb-20 md:pt-36 md:pb-28 overflow-hidden">
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent/10 via-background to-background"
      aria-hidden="true"
    >
    </div>
    <div class="container mx-auto px-4 md:px-8 max-w-4xl text-center">
      <div class="animate-fade-up">
        <span
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent/30 bg-accent/5 text-accent font-mono text-xs uppercase tracking-widest mb-8"
        >
          <Icon name="lucide:zap" class="h-3.5 w-3.5" aria-hidden="true" />
          Live demo — real AI, real call
        </span>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight">
          Your phone line, <span class="text-accent">working smarter.</span>
        </h1>

        <p
          class="text-xl md:text-2xl text-muted-foreground font-mono leading-relaxed mb-6 max-w-2xl mx-auto"
        >
          Call the number below. An AI answers, screens the call, and handles it — spam and
          junk never get through, real callers always do.
        </p>

        <p class="text-base text-muted-foreground mb-14 max-w-xl mx-auto">
          This is what it sounds like when your business line has an AI answering service
          instead of voicemail. Try it from any phone.
        </p>

        {/* CTA Card */}
        <div class="inline-block">
          <div class="bg-card border border-border rounded-2xl px-10 py-10 shadow-lg text-center">
            <p class="font-mono text-sm text-muted-foreground uppercase tracking-widest mb-3">
              Demo number
            </p>
            <a
              href={`tel:${DEMO_NUMBER}`}
              class="font-bold text-5xl md:text-6xl tracking-tight text-foreground hover:text-accent transition-colors"
              aria-label={`Call demo number ${DEMO_NUMBER_DISPLAY}`}
            >
              {DEMO_NUMBER_DISPLAY}
            </a>
            <p class="text-sm text-muted-foreground font-mono mt-2 mb-8">
              Works from any phone — mobile or desktop
            </p>

            <div class="flex justify-center">
              <span class="relative inline-flex">
                <span
                  class="absolute inset-0 rounded-full animate-ping bg-accent opacity-20 pointer-events-none"
                  aria-hidden="true"></span>
                <a
                  href={`tel:${DEMO_NUMBER}`}
                  class="relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-accent text-white font-bold text-lg rounded-full hover:bg-accent/90 active:scale-95 transition-all shadow-md"
                  aria-label={`Dial ${DEMO_NUMBER_DISPLAY}`}
                >
                  <Icon name="lucide:phone-call" class="h-5 w-5" aria-hidden="true" />
                  Dial now
                </a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* How it works */}
  <section class="py-24 bg-card border-y border-border">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What happens on every call</h2>
        <p class="text-muted-foreground font-mono max-w-xl mx-auto">
          Three things happen automatically, every time — no voicemail box, no missed
          opportunities, no spam noise.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {
          steps.map((item) => (
            <div class="p-8 bg-background border border-border rounded-xl">
              <div class="flex items-start justify-between mb-6">
                <Icon name={item.icon} class="h-7 w-7 text-accent" aria-hidden="true" />
                <span class="font-mono text-xs text-muted-foreground font-bold" aria-hidden="true">
                  {item.step}
                </span>
              </div>
              <h3 class="text-lg font-bold mb-3">{item.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Use cases */}
  <section class="py-24">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Two problems it solves cleanly</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 bg-card border border-border rounded-xl">
          <Icon name="lucide:voicemail" class="h-8 w-8 text-accent mb-6" aria-hidden="true" />
          <h3 class="text-xl font-bold mb-3">A smarter voicemail replacement</h3>
          <p class="text-muted-foreground mb-5 leading-relaxed">
            Voicemail is passive — it records everything and makes you sort through it. This
            is active: the AI asks the right questions, understands the caller&apos;s intent,
            and only surfaces what actually needs your attention.
          </p>
          <ul class="space-y-2 font-mono text-sm text-muted-foreground">
            {
              voicemailPoints.map((point) => (
                <li class="flex items-start gap-2">
                  <Icon
                    name="lucide:chevron-right"
                    class="h-4 w-4 text-accent mt-0.5 flex-shrink-0"
                    aria-hidden="true"
                  />
                  {point}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="p-8 bg-card border border-border rounded-xl">
          <Icon name="lucide:bell-off" class="h-8 w-8 text-accent mb-6" aria-hidden="true" />
          <h3 class="text-xl font-bold mb-3">Spam guard for your business line</h3>
          <p class="text-muted-foreground mb-5 leading-relaxed">
            Business lines attract robocalls. Screening them yourself wastes time; ignoring
            your phone loses real clients. The AI sits in between: every call is answered, but
            only real people get any further.
          </p>
          <ul class="space-y-2 font-mono text-sm text-muted-foreground">
            {
              spamPoints.map((point) => (
                <li class="flex items-start gap-2">
                  <Icon
                    name="lucide:chevron-right"
                    class="h-4 w-4 text-accent mt-0.5 flex-shrink-0"
                    aria-hidden="true"
                  />
                  {point}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Callback flagging callout */}
  <section class="py-16 border-y border-border bg-accent/5">
    <div class="container mx-auto px-4 md:px-8 max-w-3xl text-center">
      <Icon name="lucide:phone-off" class="h-8 w-8 text-accent mx-auto mb-5" aria-hidden="true" />
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Hang-ups don&apos;t mean lost leads</h2>
      <p class="text-muted-foreground font-mono leading-relaxed max-w-xl mx-auto">
        When a real person hangs up before leaving a message, the AI knows the difference
        between a real caller and a bot abandoning the call. Real hang-ups get flagged as a
        manual callback action — so you can follow up on your terms. Spam hang-ups disappear
        into the void, where they belong.
      </p>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="py-24">
    <div class="container mx-auto px-4 md:px-8 max-w-3xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Want this on your business line?</h2>
      <p class="text-muted-foreground font-mono mb-10 max-w-lg mx-auto">
        This is a custom-built integration — designed around your specific workflow, not a
        SaaS subscription. Let&apos;s scope it.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/#contact"
          class="inline-flex items-center justify-center px-7 py-3 bg-primary text-primary-foreground font-medium rounded-md hover:bg-primary/90 transition-colors font-mono"
        >
          Get in touch
        </a>
        <a
          href={`tel:${DEMO_NUMBER}`}
          class="inline-flex items-center justify-center gap-2 px-7 py-3 border border-border bg-background font-medium rounded-md hover:bg-card transition-colors font-mono text-muted-foreground hover:text-foreground"
        >
          <Icon name="lucide:phone" class="h-4 w-4" aria-hidden="true" />
          Call the demo again
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
