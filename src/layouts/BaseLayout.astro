---
import '@fontsource-variable/outfit/index.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '@/styles/global.css';
// Hashed build URL of the LCP font (Outfit Variable, latin) for <link rel=preload>.
// Vite resolves ?url to the same bundled file Fontsource's CSS references (deduped),
// so the preload matches the actual request. Deep-review H3, 2026-06-05.
import outfitWoff2 from '@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import { site, links, faq, knowsAbout } from '@/data/site';

interface Props {
  title: string;
  description?: string;
  /** Path for canonical + OG url, e.g. "/" or "/privacy". */
  path?: string;
  ogImage?: string;
  /** geo meta — props with defaults so routed/city pages can override. */
  geoPlacename?: string;
  geoRegion?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  path = '/',
  ogImage = '/opengraph.jpg',
  geoPlacename = site.location,
  geoRegion = `US-${site.region}`,
  noindex = false,
} = Astro.props;

// Normalize to a trailing slash so canonical + OG url match the directory-format
// served URL and the sitemap (which emits "/privacy/"). Root "/" stays as-is.
const canonicalPath = path.endsWith('/') ? path : `${path}/`;
const canonical = new URL(canonicalPath, site.url).href;
const ogImageUrl = new URL(ogImage, site.url).href;
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

// Structured data (brief §8): Organization + Services + FAQPage in one @graph.
const orgId = `${site.url}/#organization`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: site.name,
      url: site.url,
      email: site.email,
      ...(site.phone ? { telephone: site.phone } : {}),
      logo: new URL('/img/logo.svg', site.url).href,
      description: site.description,
      areaServed: 'Worldwide (remote)',
      knowsAbout: [...knowsAbout],
      founder: {
        '@type': 'Person',
        '@id': `${site.url}/#person`,
        name: site.principal,
        sameAs: [links.portfolio, links.github, links.linkedin],
      },
      contactPoint: {
        '@type': 'ContactPoint',
        email: site.email,
        ...(site.phone ? { telephone: site.phone } : {}),
        contactType: 'sales',
      },
      // Org's own ecosystem link only; the founder's personal profiles live on
      // the Person node (above) to avoid entity ambiguity. Deep-review M9.
      sameAs: [links.portfolio],
    },
    {
      '@type': 'Service',
      '@id': `${site.url}/#service-apps`,
      name: 'Custom Apps & SaaS',
      serviceType: 'Custom software & SaaS development',
      provider: { '@id': orgId },
      areaServed: 'Worldwide (remote)',
    },
    {
      '@type': 'Service',
      '@id': `${site.url}/#service-automation`,
      name: 'Automation & AI Tooling',
      serviceType: 'Business process automation & AI integration',
      provider: { '@id': orgId },
      areaServed: 'Worldwide (remote)',
    },
    {
      '@type': 'Service',
      '@id': `${site.url}/#service-infra`,
      name: 'Infrastructure, DevOps & Consulting',
      serviceType: 'Infrastructure, DevOps & technical consulting',
      provider: { '@id': orgId },
      areaServed: 'Worldwide (remote)',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={outfitWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="geo.placename" content={geoPlacename} />
    <meta name="geo.region" content={geoRegion} />
    <meta name="theme-color" content="#202a3c" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={site.shortName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.shortName} — ${title}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${site.shortName} — ${title}`} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    {
      beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
