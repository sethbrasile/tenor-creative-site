# Tenor Creative — environment variables
# Copy to .env for local dev. Real secrets live in Cloudflare Pages (encrypted),
# never in git.

# --- Public, build-time inlined (PUBLIC_*) ---
# Turnstile SITE key (public). Baked into source at deploy; default is the
# Cloudflare always-pass TEST key, so leaving this blank is fine for dev.
PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Web Analytics beacon token. Added after the Pages project exists
# (Phase 8). Blank => analytics beacon is not injected.
PUBLIC_CF_BEACON_TOKEN=

# --- Contact Function config — read by functions/api/contact.ts (Phase 4) ---
# Set via: wrangler pages secret put <KEY> --project-name tenor-creative-site
#
# Secrets (encrypted):
# TURNSTILE_SECRET_KEY=        # required — Function is fail-secure (500 if absent)
# GHL_API_KEY=                 # GHL Private Integration Token (PIT)
# N8N_WEBHOOK_SECRET=          # HMAC key; must match the n8n verify node
#
# GHL routing IDs (non-secret, but fine to store as Pages secrets):
# GHL_LOCATION_ID=             # required for GHL delivery
# GHL_PIPELINE_ID=             # optional — enables opportunity creation
# GHL_STAGE_NEW_LEAD=          # optional — pipeline stage for new leads
#
# Non-secret (wrangler.toml [vars] or Pages var):
# N8N_FALLBACK_URL=            # n8n fallback webhook; omit to disable fallback
